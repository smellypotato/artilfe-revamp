# Copy to `.env.local` for local dev / `.env` for one-off scripts.
# Do not commit files that contain real values.

# Frontend (Vite) — required for npm run dev and GitHub Pages builds
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Optional frontend tuning
# VITE_DASHBOARD_RECORD_LIMIT=3

# Legacy Firebase client config (only if using firebaseApp.ts / export tooling)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_DATABASE_URL=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_APP_ID=

# Firebase export script (npm run export:firebase) — legacy migration only
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_APP_ID=
FIREBASE_EXPORT_EMAIL=
FIREBASE_EXPORT_PASSWORD=

# Supabase import script (npm run import:supabase) — one-time migration only
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=
# FIREBASE_EXPORT_DIR=exports/firebase-2026-06-21T13-09-48-282Z
# SUPABASE_IMAGE_BUCKET=images
